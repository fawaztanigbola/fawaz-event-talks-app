# pyenv
#   For a library or app, you might want to share your .python-version if you
#   intend to maintain a consistent version of Python
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a venv, you can exclude it.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#pdm.lock
.pdm-plugins/
.pdm-build/

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

